# DataGolf API - Get your key at https://datagolf.com
DATA_GOLF_API_KEY=your_api_key_here

# Supabase - Get these from your Supabase project settings > API
# Prefer publishable keys if available; anon keys still work during migration.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only (optional): use only for admin operations that must bypass RLS.
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# Supabase CLI — used by db:* scripts only, not at runtime.
# Find your project ref in Dashboard > Settings > General > Reference ID.
SUPABASE_PROJECT_REF=your_project_ref_here

# Sentry — Error tracking (free tier: 5K errors/month)
# Get your DSN from Settings > Projects > [project] > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Sentry source maps — build-time only, set in Vercel env vars
# SENTRY_ORG=your_sentry_org
# SENTRY_PROJECT=your_sentry_project
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
